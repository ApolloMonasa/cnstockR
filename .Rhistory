# 获取数据
mt <- cnstockR::cn_get_daily("600519", "2022-01-01")
CSI300 <- cnstockR::cn_get_daily("000300", "2022-01-01")
# 处理
mt <- mt %>%
select(date, close) %>%
rename(mt_close = close)
# 处理
mt <- select(mt, data, close) |>
rename(date = data, price = close) |>
mutate(date = as.Date(date))
library("cnstockR")
library("ggplot2")
library("dplyr")
# 处理
mt <- mt %>%
select(date, close) %>%
rename(mt_close = close)
CSI300 <- CSI300 %>%
select(date, close) %>%
rename(CSI300_close = close)
data <- merge(mt, CSI300, by = "date")
# 绘图
ggplot(data, aes(x = date)) +
geom_line(aes(y = mt_close, color = "茅台"), size =
1) +
geom_line(aes(y = CSI300_close, color = "沪深300"), size
= 1) +
labs(title = "茅台与沪深300的收盘价走势",
x = "日期",
y = "收盘价") +
scale_color_manual(values = c("茅台" = "blue", "沪深
300" = "red")) +
theme_minimal() +
theme(legend.title = element_blank())
